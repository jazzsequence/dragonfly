---
import Base from '../layouts/Base.astro';
import { getContentByType } from '../lib/content.ts';
import { url } from '../lib/utils.ts';

const posts = await getContentByType('posts');
const docs = await getContentByType('docs');

// Sort posts by date descending
const sortedPosts = posts
  .filter((p) => p.date)
  .sort((a, b) => new Date(b.date!).getTime() - new Date(a.date!).getTime());
---

<Base>
  <div class="hero">
    <h1>Dragonfly</h1>
    <p class="tagline">Developer blog for the <a href="https://github.com/jazzsequence/Invert">Invert</a> project.</p>
  </div>

  {sortedPosts.length > 0 ? (
    <div class="posts">
      <h2>Recent posts</h2>
      <ul class="post-list">
        {sortedPosts.map((post) => (
          <li class="post-item">
            <a href={url('posts/' + post.slug)}>{post.title}</a>
            {post.date && <time class="post-date">{new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>}
            {post.excerpt && <p class="post-excerpt">{post.excerpt}</p>}
          </li>
        ))}
      </ul>
    </div>
  ) : (
    <div class="empty-state">
      <p>No posts yet. Create the first one with <code>invert_create</code>.</p>
    </div>
  )}

  {docs.length > 0 && (
    <div class="docs-toc">
      <h2>Invert docs</h2>
      <ul>
        {docs.map((doc) => (
          <li>
            <a href={url('docs/' + doc.slug)}>{doc.title}</a>
            {doc.excerpt && <span class="doc-excerpt"> — {doc.excerpt}</span>}
          </li>
        ))}
      </ul>
    </div>
  )}
</Base>

<style>
  .hero { margin-bottom: 2rem; }
  .hero h1 { font-size: 3rem; margin: 0 0 0.5rem; }
  .hero a { color: inherit; }
  .tagline { font-size: 1.2rem; color: #555; margin: 0; }

  .posts { margin-bottom: 3rem; }
  .posts h2 { font-size: 1.4rem; margin-bottom: 1rem; }
  .post-list { list-style: none; padding: 0; margin: 0; }
  .post-item {
    padding: 1.25rem 0;
    border-bottom: 1px solid #f0f0f0;
  }
  .post-item:last-child { border-bottom: none; }
  .post-item a {
    font-size: 1.15rem;
    font-weight: 600;
    color: #0066cc;
    text-decoration: none;
  }
  .post-item a:hover { text-decoration: underline; }
  .post-date {
    display: block;
    font-size: 0.85rem;
    color: #888;
    margin-top: 0.2rem;
  }
  .post-excerpt {
    margin: 0.4rem 0 0;
    font-size: 0.95rem;
    color: #444;
    line-height: 1.5;
  }

  .empty-state {
    padding: 2rem;
    background: #f9f9f9;
    border-radius: 6px;
    color: #666;
    margin-bottom: 3rem;
  }
  .empty-state code {
    background: #eee;
    padding: 0.1em 0.4em;
    border-radius: 3px;
    font-size: 0.9em;
  }

  .docs-toc h2 { font-size: 1.4rem; margin-bottom: 0.75rem; }
  .docs-toc ul { list-style: none; padding: 0; margin: 0; }
  .docs-toc li { padding: 0.4rem 0; border-bottom: 1px solid #f0f0f0; }
  .docs-toc li:last-child { border-bottom: none; }
  .docs-toc a { text-decoration: none; color: #0066cc; font-weight: 500; }
  .docs-toc a:hover { text-decoration: underline; }
  .doc-excerpt { color: #888; font-size: 0.9rem; }
</style>
