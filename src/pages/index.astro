---
export const prerender = false;

import Base from '../layouts/Base.astro';
import { getContentByType } from '../lib/content.ts';
import { url } from '../lib/utils.ts';
import type { InvertContent } from '../adapters/interface.ts';

// Static adapter content
const staticPosts = await getContentByType('posts');
const docs = await getContentByType('docs');

// Layer KV posts on top for immediate visibility of MCP-written content
let posts: InvertContent[] = staticPosts;
try {
  const runtime = (Astro.locals as { runtime?: { env?: { CONTENT?: { get(k: string): Promise<string | null> } } } }).runtime;
  const kv = runtime?.env?.CONTENT;
  if (kv) {
    const indexRaw = await kv.get('_index');
    if (indexRaw) {
      const kvIndex = JSON.parse(indexRaw) as Array<{
        type: string; slug: string; title: string;
        excerpt?: string | null; date?: string | null; author?: string | null;
      }>;
      const kvPosts = kvIndex.filter((e) => e.type === 'posts');
      if (kvPosts.length > 0) {
        const merged = new Map<string, InvertContent>();
        for (const item of staticPosts) merged.set(item.slug, item);
        for (const entry of kvPosts) {
          merged.set(entry.slug, {
            id: entry.slug, slug: entry.slug, title: entry.title, body: '',
            contentType: 'posts', excerpt: entry.excerpt ?? undefined,
            date: entry.date ?? undefined, author: entry.author ?? undefined,
          });
        }
        posts = [...merged.values()];
      }
    }
  }
} catch {
  // KV unavailable in local dev
}

// Sort posts by date descending
const sortedPosts = posts
  .filter((p) => p.date)
  .sort((a, b) => new Date(b.date!).getTime() - new Date(a.date!).getTime());
---

<Base>
  <div class="hero">
    <h1>Dragonfly</h1>
    <p class="tagline">Developer blog for the <a href="https://github.com/jazzsequence/Invert">Invert</a> project.</p>
  </div>

  {sortedPosts.length > 0 ? (
    <div class="posts">
      <h2>Recent posts</h2>
      <ul class="post-list">
        {sortedPosts.map((post) => (
          <li class="post-item">
            <a href={url('posts/' + post.slug)}>{post.title}</a>
            {post.date && <time class="post-date">{new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>}
            {post.excerpt && <p class="post-excerpt">{post.excerpt}</p>}
          </li>
        ))}
      </ul>
    </div>
  ) : (
    <div class="empty-state">
      <p>No posts yet. Create the first one with <code>invert_create</code>.</p>
    </div>
  )}

  {docs.length > 0 && (
    <div class="docs-toc">
      <h2>Invert docs</h2>
      <ul>
        {docs.map((doc) => (
          <li>
            <a href={url('docs/' + doc.slug)}>{doc.title}</a>
            {doc.excerpt && <span class="doc-excerpt"> — {doc.excerpt}</span>}
          </li>
        ))}
      </ul>
    </div>
  )}
</Base>

<style>
  .hero { margin-bottom: 2.5rem; }
  .hero h1 {
    font-size: 3.5rem;
    margin: 0 0 0.5rem;
    font-family: var(--font-heading);
    color: var(--color-accent);
    text-shadow:
      0 0 20px rgba(0, 229, 204, 0.4),
      0 0 40px rgba(0, 229, 204, 0.2);
    letter-spacing: -0.01em;
  }
  .hero a { color: var(--color-accent); }
  .tagline { font-size: 1.2rem; color: var(--color-text-sub); margin: 0; }

  .posts { margin-bottom: 3rem; }
  .posts h2 { font-size: 1.4rem; margin-bottom: 1rem; color: var(--color-text); }
  .post-list { list-style: none; padding: 0; margin: 0; }
  .post-item {
    padding: 1.25rem 0;
    border-bottom: 1px solid var(--color-border);
  }
  .post-item:last-child { border-bottom: none; }
  .post-item a {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.15s;
  }
  .post-item a:hover { color: var(--color-accent); }
  .post-date {
    display: block;
    font-size: 0.85rem;
    color: var(--color-muted);
    margin-top: 0.2rem;
    font-family: var(--font-mono);
  }
  .post-excerpt {
    margin: 0.4rem 0 0;
    font-size: 0.95rem;
    color: var(--color-text-sub);
    line-height: 1.5;
  }

  .empty-state {
    padding: 2rem;
    background: var(--color-surface-tag);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-muted);
    margin-bottom: 3rem;
  }
  .empty-state code {
    background: var(--color-surface);
    color: var(--color-accent);
    padding: 0.1em 0.4em;
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 0.9em;
  }

  .docs-toc h2 { font-size: 1.4rem; margin-bottom: 0.75rem; color: var(--color-text); }
  .docs-toc ul { list-style: none; padding: 0; margin: 0; }
  .docs-toc li { padding: 0.4rem 0; border-bottom: 1px solid var(--color-border); }
  .docs-toc li:last-child { border-bottom: none; }
  .docs-toc a { text-decoration: none; color: var(--color-accent); font-weight: 500; }
  .docs-toc a:hover { color: var(--color-accent-2); }
  .doc-excerpt { color: var(--color-muted); font-size: 0.9rem; }
</style>
