---
import Base from '../../layouts/Base.astro';
import ContentBody from '../../components/ContentBody.astro';
import { getAllContent, getContentBySlug } from '../../lib/content.ts';
import { url } from '../../lib/utils.ts';

export async function getStaticPaths() {
  const all = await getAllContent();
  return all.map((item) => ({
    params: { type: item.contentType, slug: item.slug },
  }));
}

const { type, slug } = Astro.params;
const content = await getContentBySlug(type, slug);
---

<Base title={content?.title}>
  {content ? (
    <>
      <a href={url(`${type}/`)} class="back-link">← {type}</a>
      <ContentBody content={content} />
    </>
  ) : (
    <p>Content not found.</p>
  )}
</Base>

<style>
  .back-link {
    display: inline-block;
    color: #888;
    text-decoration: none;
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
    text-transform: capitalize;
  }
  .back-link:hover { color: #000; }
</style>
