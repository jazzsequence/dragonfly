---
import Base from '../../layouts/Base.astro';
import ContentBody from '../../components/ContentBody.astro';
import { getAllContent } from '../../lib/content.ts';
import { url } from '../../lib/utils.ts';
import type { InvertContent } from '../../adapters/interface.ts';

export async function getStaticPaths() {
  const all = await getAllContent();
  return all.map((item) => ({
    params: { type: item.contentType, slug: item.slug },
    props: { content: item },
  }));
}

interface Props { content: InvertContent; }
const { content } = Astro.props;
const { type } = Astro.params as { type: string };
const canonicalUrl = Astro.site
  ? new URL(Astro.url.pathname, Astro.site).toString()
  : undefined;
---

<Base
  title={content?.title}
  description={content?.excerpt}
  image={content?.featuredImage}
  canonicalUrl={canonicalUrl}
  ogType="article"
>
  {content ? (
    <>
      <a href={url(`${type}/`)} class="back-link">← {type}</a>
      <ContentBody content={content} />
    </>
  ) : (
    <p>Content not found.</p>
  )}
</Base>

<style>
  .back-link {
    display: inline-block;
    color: var(--color-muted);
    text-decoration: none;
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
    text-transform: capitalize;
  }
  .back-link:hover { color: var(--color-text); }
</style>
