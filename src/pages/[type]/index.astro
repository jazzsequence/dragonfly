---
export const prerender = true;

import Base from '../../layouts/Base.astro';
import ContentCard from '../../components/ContentCard.astro';
import { getAllContent } from '../../lib/content.ts';
import type { InvertContent } from '../../adapters/interface.ts';

export async function getStaticPaths() {
  const all = await getAllContent();
  const types = [...new Set(all.map((c) => c.contentType))];
  return types.map((type) => ({
    params: { type },
    props: { items: all.filter((c) => c.contentType === type) },
  }));
}

interface Props { items: InvertContent[]; }
const { type } = Astro.params as { type: string };
const { items } = Astro.props;
---

<Base title={type}>
  <h1 class="type-heading">{type}</h1>
  {items.length === 0 && <p>No content of type <strong>{type}</strong> found.</p>}
  {items.map((item) => <ContentCard content={item} />)}
</Base>

<style>
  .type-heading { text-transform: capitalize; }
</style>
